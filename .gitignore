# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...mas versiona o exemplo
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# assets de referência / downloads — NÃO versionar (não usados pelo app;
# as imagens em uso ficam em public/background e as fontes vêm do Google via next/font)
/src/background/
/src/fonts/

# PNGs-fonte pesados dos ícones/OG (as versões otimizadas em app/ e public/icons são versionadas)
/src/logo/favicon-case-ja.png
/src/logo/opengraph-case-ja.png
/src/logo/case-ja-favicon.png
/src/logo/case-ja-og.png

# Mockup/assets-fonte do tema luxury (versões otimizadas ficam em public/luxe e public/background)
/src/simbolos/

# Vídeo-fonte do reel (o servido fica em public/reel.mp4)
/src/Video/

.vercel
