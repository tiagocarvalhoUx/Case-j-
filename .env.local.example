# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# Painel Supabase → Project Settings → API Keys

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (publishable / anon) — segura para o navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional) URL pública do site em produção, usada nos metadados/OG.
# Em produção na Vercel, defina como https://seu-dominio (ou a URL da Vercel).
# NEXT_PUBLIC_SITE_URL=https://case-ja.com.br
