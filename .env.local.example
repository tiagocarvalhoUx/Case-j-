# Copie este arquivo para .env.local e preencha com as chaves reais.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (secret) — usada no servidor (webhook do Asaas confirma pagamentos)
SUPABASE_SERVICE_ROLE_KEY=

# (Opcional) URL pública do site em produção, usada nos metadados/OG.
# NEXT_PUBLIC_SITE_URL=https://case-ja.com.br

# --- Asaas (gateway de pagamento) ---
# "sandbox" para testes (sem cobrar) ou "production" para pagamentos reais
ASAAS_ENV=sandbox
ASAAS_API_KEY=
# Token do webhook (defina o mesmo valor no painel Asaas → Webhooks)
ASAAS_WEBHOOK_TOKEN=
